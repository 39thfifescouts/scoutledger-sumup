# Copy to .env and fill in values for local runs
# NEVER commit .env to git

# SumUp personal access token (https://developer.sumup.com/docs/authorization)
SUMUP_API_KEY=your_sumup_personal_access_token
SUMUP_WEBHOOK_SECRET=your_sumup_webhook_secret

# Xero OAuth2 (from your Xero app at developer.xero.com)
XERO_CLIENT_ID=your_xero_client_id
XERO_CLIENT_SECRET=your_xero_client_secret
XERO_TENANT_ID=your_xero_organisation_id
XERO_REFRESH_TOKEN=your_xero_refresh_token

# Xero bank account ID (the account SumUp settlements land in)
# Find it: Xero → bank account → Settings → UUID in the URL
XERO_BANK_ACCOUNT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Xero account codes (the number shown in Chart of Accounts, not the name)
XERO_ACCOUNT_CARD_SALES=200    # SumUp card payment income
XERO_ACCOUNT_FEES=404          # SumUp transaction fees

# Xero tracking category names (must match exactly what's in Xero)
XERO_TRACKING_FUND_TYPE=Fund Type
XERO_TRACKING_GROUP_ACTIVITIES=Group Activities
