# Copy to .env and fill in values for local runs
# NEVER commit .env to git

# SumUp personal access token (https://developer.sumup.com/docs/authorization)
SUMUP_API_KEY=

# Xero OAuth2 (from your Xero app at developer.xero.com)
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
XERO_TENANT_ID=
XERO_REFRESH_TOKEN=

# Xero bank account ID (the SumUp settlement account — Settings → UUID in the URL)
XERO_BANK_ACCOUNT_ID=

# Xero tracking category names (must match exactly what's in Xero)
XERO_TRACKING_FUND_TYPE=Fund Type
XERO_TRACKING_GROUP_ACTIVITIES=Group Activities

# How many days back to look for payouts on each run
LOOKBACK_DAYS=8

# Email notifications via Resend (optional)
NOTIFY_EMAIL=
RESEND_API_KEY=
